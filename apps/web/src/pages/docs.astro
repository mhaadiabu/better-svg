  <span class="token-punct">{"{#"}</span><span class="token-keyword">snippet</span> fallback<span class="token-punct">(){"}"}</span><span class="token-component">Fallback</span><span class="token-punct">{"{/"}</span><span class="token-keyword">snippet</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"</"}</span><span class="token-component">SVG</span><span class="token-punct">{">"}</span></pre>
