                    <pre class="p-4 text-sm leading-6"><span class="token-keyword">import</span> <span class="token-string">'package:http/http.dart'</span> <span class="token-keyword">as</span> http<span class="token-punct">;</span>
<span class="token-keyword">import</span> <span class="token-string">'package:svg_flutter/svg_flutter.dart'</span><span class="token-punct">;</span>

<span class="token-component">Svg</span><span class="token-punct">(</span>
  <span class="token-prop">src</span><span class="token-punct">:</span> <span class="token-string">'https://cdn.example.com/icon.svg'</span><span class="token-punct">,</span>
  <span class="token-prop">width</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
  <span class="token-prop">height</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
  <span class="token-prop">color</span><span class="token-punct">:</span> <span class="token-keyword">const</span> <span class="token-component">Color</span><span class="token-punct">(</span><span class="token-string">0xFF111827</span><span class="token-punct">),</span>
  <span class="token-prop">fit</span><span class="token-punct">:</span> <span class="token-component">BoxFit</span><span class="token-punct">.</span>contain<span class="token-punct">,</span>
  <span class="token-prop">alignment</span><span class="token-punct">:</span> <span class="token-component">Alignment</span><span class="token-punct">.</span>center<span class="token-punct">,</span>
  <span class="token-prop">matchTextDirection</span><span class="token-punct">:</span> <span class="token-keyword">true</span><span class="token-punct">,</span>
  <span class="token-prop">allowDrawingOutsideViewBox</span><span class="token-punct">:</span> <span class="token-keyword">false</span><span class="token-punct">,</span>
