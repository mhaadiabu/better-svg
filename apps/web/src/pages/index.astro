---
import Base from "../layouts/Base.astro";

const marqueeItems = [
  "React",
  "React Native",
  "Vue",
  "Svelte",
  "Flutter",
  "inline rendering",
  "zero wrappers",
  "sanitized by default",
  "remote URLs",
  "local names",
  "data: URIs",
  "memory caching",
  "loading & fallback",
];

const frameworkBadges = [
  { id: "react", name: "React", sub: "@mhaadi/svg/react" },
  { id: "react-native", name: "React Native", sub: "@mhaadi/svg/react-native" },
  { id: "vue", name: "Vue", sub: "@mhaadi/svg/vue" },
  { id: "svelte", name: "Svelte", sub: "@mhaadi/svg/svelte" },
  { id: "flutter", name: "Flutter", sub: "svg_flutter" },
];

const featureCards = [
  {
    icon: `<path d="M12 3v1m0 16v1M4.22 4.22l.707.707m12.728 12.728.707.707M1 12h2m18 0h2M4.22 19.78l.707-.707M18.071 5.929l.707-.707" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
    title: "Inline rendering",
    desc: "Renders actual <svg> elements — not <img> tags — so CSS currentColor, animations, and JavaScript all work natively across every adapter.",
  },
  {
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: "Built-in sanitization",
    desc: "Strips <script>, event handlers, unsafe hrefs, and embedded HTML by default. Safely render untrusted SVG content in any framework.",
  },
  {
    icon: `<path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z" stroke="currentColor" stroke-width="1.5"/><polyline points="13 2 13 9 20 9" stroke="currentColor" stroke-width="1.5"/>`,
    title: "Four source types",
    desc: "Pass an inline SVG string, a data: URL, a remote HTTPS URL, or just a local name. One mental model, every source.",
  },
  {
    icon: `<ellipse cx="12" cy="12" rx="10" ry="4" stroke="currentColor" stroke-width="1.5"/><path d="M2 12c0 2.21 4.477 4 10 4s10-1.79 10-4" stroke="currentColor" stroke-width="1.5"/><path d="M2 16c0 2.21 4.477 4 10 4s10-1.79 10-4" stroke="currentColor" stroke-width="1.5"/>`,
    title: "Memory caching",
    desc: "Remote SVGs are cached in-memory by URL. Eliminates duplicate network requests on re-render in every adapter.",
  },
  {
    icon: `<polyline points="16 18 22 12 16 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="8 6 2 12 8 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
    title: "Full prop forwarding",
    desc: "Every standard SVG attribute is forwarded and overrides markup attributes. className, onClick, aria-*, width, height, color — everything.",
  },
  {
    icon: `<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
    title: "Loading & fallback",
    desc: "Render a loading state while fetching and a fallback state on error. Slots in Vue, snippets in Svelte, Widgets in Flutter.",
  },
];
---

<Base title="BetterSVG — Inline SVG for React, React Native, Vue, Svelte, Flutter">
  <!-- NAV -->
  <nav class="sticky top-0 left-0 right-0 z-50 border-b border-coal-2 bg-coal/90 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 lg:px-4 py-3 lg:py-4">
      <a href="/" class="flex items-center gap-2.5 group">
        <svg class="h-6 w-6 text-acid group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 8 Q12 2 20 8 Q12 14 4 8Z" fill="currentColor" opacity="0.9"/>
          <path d="M4 16 Q12 10 20 16 Q12 22 4 16Z" fill="currentColor" opacity="0.4"/>
        </svg>
        <span class="font-display text-xl tracking-wider text-[#e8e8e8]">BETTERSVG</span>
      </a>

      <div class="hidden items-center gap-8 md:flex">
        <a href="/docs" class="link-underline text-sm text-zinc-muted hover:text-[#e8e8e8] transition-colors">Docs</a>
        <a href="https://github.com/mhaadiabu/better-svg" class="link-underline text-sm text-zinc-muted hover:text-[#e8e8e8] transition-colors" target="_blank">GitHub</a>
        <a
          href="/docs"
          class="flex items-center gap-2 border border-acid bg-acid px-4 py-1.5 text-sm font-medium text-coal transition-all hover:bg-acid-dim hover:border-acid-dim"
        >
          Get started
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden text-zinc-muted hover:text-acid transition-colors p-1" aria-label="Menu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden border-t border-coal-2 px-4 py-4 md:hidden">
      <div class="flex flex-col gap-4">
        <a href="/docs" class="text-sm text-zinc-muted hover:text-acid transition-colors">Docs</a>
        <a href="https://github.com/mhaadiabu/better-svg" class="text-sm text-zinc-muted hover:text-acid transition-colors">GitHub</a>
        <a href="/docs" class="text-sm font-medium text-acid">Get started →</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative lg:min-h-screen overflow-x-hidden pt-4 lg:pt-8">
    <!-- Background grid -->
    <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-100 pointer-events-none"></div>

    <!-- Diagonal acid stripe -->
    <div
      class="absolute top-0 right-0 h-full w-[45%] pointer-events-none"
      style="background: linear-gradient(135deg, transparent 40%, rgba(185,255,75,0.03) 40%, rgba(185,255,75,0.05) 60%, transparent 60%);"
    ></div>

    <!-- Large SVG path decoration -->
    <svg class="absolute bottom-0 left-0 w-full opacity-[0.04] pointer-events-none" viewBox="0 0 1440 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 150 C200 50 400 250 600 150 S1000 50 1200 150 S1400 250 1440 150 L1440 300 L0 300Z" fill="#b9ff4b"/>
    </svg>

    <!-- Scan line effect -->
    <div class="scan-line"></div>

    <div class="relative mx-auto max-w-6xl px-4 pt-10 pb-16 lg:pt-20 lg:pb-32">
      <div class="grid lg:grid-cols-2 lg:gap-12 items-center">

        <!-- Left: Text -->
        <div class="min-w-0">

        <!-- Badge -->
        <div class="mb-8 inline-flex items-center gap-2 border border-coal-4 bg-coal-1 px-3 py-1.5 animate-fade-in delay-100">
          <span class="h-1.5 w-1.5 bg-acid animate-pulse"></span>
          <span class="font-mono text-xs text-zinc-muted">v0.2.1 — now on npm</span>
        </div>

        <!-- Headline -->
        <h1 class="font-display leading-none tracking-wider animate-fade-up delay-200">
          <span class="inline-block lg:block mr-3 text-[clamp(3rem,9vw,7rem)] text-[#e8e8e8]">BETTER</span><!--
          --><span class="inline-block lg:block text-[clamp(3rem,9vw,7rem)] text-acid acid-glow">SVG</span>
          <span class="block text-[clamp(1.25rem,2.5vw,1.75rem)] text-zinc-muted font-mono font-light tracking-normal mt-2">Inline SVG done right.</span>
        </h1>

        <!-- Sub -->
        <p class="mt-8 max-w-md text-base text-zinc-muted leading-relaxed animate-fade-up delay-400">
          Resolve, sanitize, and render SVGs inline in React, React Native, Vue,
          Svelte, and Flutter. From local names to remote URLs — with full control
          over props, caching, and security.
        </p>

        <!-- CTA buttons -->
        <div class="mt-8 flex flex-wrap items-center gap-4 animate-fade-up delay-600">
          <a
            href="/docs"
            class="group flex items-center gap-2 bg-acid px-5 py-2.5 text-sm font-semibold text-coal transition-all hover:bg-acid-dim hover:gap-3"
          >
            Read the docs
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="https://github.com/mhaadiabu/better-svg"
            target="_blank"
            class="flex items-center gap-2 border border-coal-4 px-5 py-2.5 text-sm text-zinc-muted transition-all hover:border-acid hover:text-acid"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </a>
        </div>
        </div>

        <!-- Right: Tabbed code example -->
        <div class="mt-12 lg:mt-0 animate-fade-in delay-700 min-w-0">
          <div class="relative">
            <!-- Floating file label -->
            <div class="absolute -top-3 right-4 z-10 border border-coal-4 bg-coal px-2 py-0.5 font-mono text-[10px] text-zinc-muted">
              <span data-fw-tab-label>App.tsx</span>
            </div>

            <!-- Glow behind card -->
            <div class="absolute -inset-px bg-linear-to-br from-acid/10 via-transparent to-transparent blur-xl"></div>

            <div class="relative border border-coal-4 bg-coal">
              <!-- Tab bar -->
              <div class="flex border-b border-coal-2 overflow-x-auto" data-fw-tabs>
                <button type="button" class="fw-tab is-active" data-fw-tab="react">React</button>
                <button type="button" class="fw-tab" data-fw-tab="react-native">React Native</button>
                <button type="button" class="fw-tab" data-fw-tab="vue">Vue</button>
                <button type="button" class="fw-tab" data-fw-tab="svelte">Svelte</button>
                <button type="button" class="fw-tab" data-fw-tab="flutter">Flutter</button>
              </div>

              <!-- Code panels -->
              <div data-fw-panels>
                <pre data-fw-panel="react" class="p-5 text-sm leading-7 overflow-x-auto"><span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/react"</span><span class="token-punct">;</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
  <span class="token-prop">className</span><span class="token-punct">=</span><span class="token-string">"h-6 w-6 text-current"</span>
  <span class="token-prop">loading</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">"Loading…"</span><span class="token-punct">{"}"}</span>
  <span class="token-prop">fallback</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">"Failed"</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"/>"}</span></pre>
                <pre data-fw-panel="react-native" class="p-5 text-sm leading-7 overflow-x-auto" hidden><span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/react-native"</span><span class="token-punct">;</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">name</span><span class="token-punct">=</span><span class="token-string">"logo"</span>
  <span class="token-prop">width</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">24</span><span class="token-punct">{"}"}</span>
  <span class="token-prop">height</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">24</span><span class="token-punct">{"}"}</span>
  <span class="token-prop">color</span><span class="token-punct">=</span><span class="token-string">"#111827"</span>
<span class="token-punct">{"/>"}</span></pre>
                <pre data-fw-panel="vue" class="p-5 text-sm leading-7 overflow-x-auto" hidden><span class="token-punct">{"<"}</span><span class="token-keyword">script</span> <span class="token-prop">setup</span> <span class="token-prop">lang</span><span class="token-punct">=</span><span class="token-string">"ts"</span><span class="token-punct">{">"}</span>
  <span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/vue"</span><span class="token-punct">;</span>
<span class="token-punct">{"</"}</span><span class="token-keyword">script</span><span class="token-punct">{">"}</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
  <span class="token-prop">:width</span><span class="token-punct">=</span><span class="token-string">24</span>
  <span class="token-prop">:height</span><span class="token-punct">=</span><span class="token-string">24</span>
<span class="token-punct">{"/>"}</span></pre>
                <pre data-fw-panel="svelte" class="p-5 text-sm leading-7 overflow-x-auto" hidden><span class="token-punct">{"<"}</span><span class="token-keyword">script</span> <span class="token-prop">lang</span><span class="token-punct">=</span><span class="token-string">"ts"</span><span class="token-punct">{">"}</span>
  <span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/svelte"</span><span class="token-punct">;</span>
<span class="token-punct">{"</"}</span><span class="token-keyword">script</span><span class="token-punct">{">"}</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
  <span class="token-prop">width</span><span class="token-punct">=</span><span class="token-string">"24"</span>
  <span class="token-prop">height</span><span class="token-punct">=</span><span class="token-string">"24"</span>
<span class="token-punct">{"/>"}</span></pre>
                <pre data-fw-panel="flutter" class="p-5 text-sm leading-7 overflow-x-auto" hidden><span class="token-keyword">import</span> <span class="token-string">'package:svg_flutter/svg_flutter.dart'</span><span class="token-punct">;</span>

<span class="token-component">Svg</span><span class="token-punct">(</span>
  <span class="token-prop">src</span><span class="token-punct">:</span> <span class="token-string">'https://cdn.example.com/icon.svg'</span><span class="token-punct">,</span>
  <span class="token-prop">width</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
  <span class="token-prop">height</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
  <span class="token-prop">color</span><span class="token-punct">:</span> <span class="token-keyword">const</span> <span class="token-component">Color</span><span class="token-punct">(</span><span class="token-string">0xFF111827</span><span class="token-punct">),</span>
  <span class="token-prop">loading</span><span class="token-punct">:</span> <span class="token-keyword">const</span> <span class="token-component">CircularProgressIndicator</span><span class="token-punct">(),</span>
  <span class="token-prop">fallback</span><span class="token-punct">:</span> <span class="token-keyword">const</span> <span class="token-component">Icon</span><span class="token-punct">(</span><span class="token-component">Icons</span><span class="token-punct">.</span>broken_image<span class="token-punct">),</span>
<span class="token-punct">)</span></pre>
              </div>
            </div>

            <!-- Rendered output strip -->
            <div class="mt-4 flex items-center justify-center gap-6 border border-coal-2 bg-coal-1 px-4 py-4">
              <span class="font-mono text-xs text-zinc-muted">rendered output →</span>
              <svg class="h-10 w-10 text-acid animate-float" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                <rect x="6" y="6" width="52" height="52" rx="0" fill="currentColor" opacity="0.15"/>
                <path d="M20 32h24" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
                <path d="M32 20v24" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              </svg>
              <svg class="h-10 w-10 text-[#79b8ff] animate-float" style="animation-delay:0.8s" viewBox="0 0 64 64">
                <circle cx="32" cy="32" r="24" fill="currentColor" opacity="0.15"/>
                <path d="M22 32 L32 22 L42 32 L32 42Z" fill="currentColor" opacity="0.7"/>
              </svg>
              <svg class="h-10 w-10 text-[#f8c8d4] animate-float" style="animation-delay:1.4s" viewBox="0 0 64 64">
                <path d="M32 8 L56 52 L8 52Z" fill="currentColor" opacity="0.15"/>
                <path d="M32 20 L46 44 L18 44Z" fill="currentColor" opacity="0.6"/>
              </svg>
            </div>

            <!-- Install snippet -->
            <div class="mt-4">
              <div class="code-block max-w-sm" data-lang="sh">
                <pre class="px-4 py-3 text-sm"><span class="token-comment">$</span> <span class="text-[#e8e8e8]">pnpm add @mhaadi/svg</span></pre>
              </div>
              <div class="code-block max-w-sm mt-2" data-lang="sh">
                <pre class="px-4 py-3 text-sm"><span class="token-comment">$</span> <span class="text-[#e8e8e8]">flutter pub add svg_flutter</span></pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE strip -->
  <div class="overflow-hidden border-y border-coal-2 bg-coal-1 py-3">
    <div class="marquee-track flex whitespace-nowrap gap-0">
      {
        Array.from({ length: 2 }).map(() => (
          <span class="inline-flex shrink-0 gap-0">
            {marqueeItems.map((item) => (
              <span class="inline-flex items-center gap-4 px-4 font-mono text-xs text-zinc-muted uppercase tracking-widest">
                <span class="h-1 w-1 bg-acid/40 shrink-0"></span>
                {item}
              </span>
            ))}
          </span>
        ))
      }
    </div>
  </div>

  <!-- FRAMEWORKS -->
  <section id="frameworks" class="border-y border-coal-2 bg-coal-1">
    <div class="mx-auto max-w-6xl px-4 py-16 lg:py-24">
      <div class="mb-10 lg:mb-14 flex items-end justify-between gap-4">
        <div>
          <p class="mb-2 font-mono text-xs tracking-widest text-acid uppercase">Five adapters, one mental model</p>
          <h2 class="font-display text-5xl tracking-wider text-[#e8e8e8]">FRAMEWORKS</h2>
        </div>
        <a href="/docs" class="hidden sm:flex items-center gap-2 text-sm text-zinc-muted hover:text-acid transition-colors group">
          Read the API
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="grid gap-px bg-coal-2 sm:grid-cols-2 lg:grid-cols-5 overflow-hidden border border-coal-2">
        {frameworkBadges.map((fw) => (
          <a href={`/docs?fw=${fw.id}`} class="group bg-coal p-6 hover:bg-coal-1 transition-colors flex flex-col gap-3">
            <div class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 bg-acid shrink-0"></span>
              <span class="font-mono text-[10px] tracking-widest text-zinc-muted uppercase">Adapter</span>
            </div>
            <h3 class="font-display text-2xl tracking-wider text-[#e8e8e8]">{fw.name}</h3>
            <code class="font-mono text-[11px] text-zinc-muted break-all">{fw.sub}</code>
            <div class="mt-auto flex items-center gap-1.5 font-mono text-[11px] text-zinc-muted group-hover:text-acid transition-colors">
              Read docs
              <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES GRID -->
  <section id="features" class="mx-auto max-w-6xl px-4 py-16 lg:py-28">
    <div class="mb-10 lg:mb-16 flex items-end justify-between gap-4">
      <div>
        <p class="mb-2 font-mono text-xs tracking-widest text-acid uppercase">Why BetterSVG</p>
        <h2 class="font-display text-5xl tracking-wider text-[#e8e8e8]">FEATURES</h2>
      </div>
      <a href="/docs" class="hidden sm:flex items-center gap-2 text-sm text-zinc-muted hover:text-acid transition-colors group">
        Full API reference
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none">
