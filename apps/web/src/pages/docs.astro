---
import Base from "../layouts/Base.astro";
import FrameworkPicker from "../components/FrameworkPicker.astro";
import { frameworks } from "../data/frameworks";

const sections = [
  { id: "overview", label: "Overview" },
  { id: "installation", label: "Installation" },
  { id: "usage", label: "Usage" },
  { id: "props", label: "Props" },
  { id: "framework-specifics", label: "Framework Specifics" },
  { id: "source-types", label: "Source Types" },
  { id: "security", label: "Security" },
  { id: "edge-cases", label: "Edge Cases" },
  { id: "examples", label: "Examples" },
];

const strippedElements = [
  { elem: "<script>", reason: "Arbitrary JS execution" },
  { elem: "<foreignObject>", reason: "Embedded HTML injection" },
  { elem: "<iframe>", reason: "External frame embedding" },
  { elem: "<object>", reason: "Plugin execution vector" },
  { elem: "<embed>", reason: "Plugin execution vector" },
  { elem: "on* attributes", reason: "Inline event handler XSS" },
  { elem: "unsafe href", reason: "javascript: URL injection" },
  { elem: "unsafe xlink:href", reason: "XLink javascript: URLs" },
];

const flutterNotes = [
  "svg_flutter is a separate pub package and is not a subpath of @mhaadi/svg.",
  "It depends on flutter_svg (peer) and http for remote fetching.",
  "Sanitization is performed against the raw markup before passing to SvgPicture.string.",
];
---

<Base
  title="Docs — BetterSVG"
  description="Full API reference for @mhaadi/svg and svg_flutter — the inline SVG components for React, React Native, Vue, Svelte, and Flutter."
>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-coal-2 bg-coal/90 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 lg:px-4 py-3 lg:py-4">
      <a href="/" class="flex items-center gap-2.5 group">
        <svg class="h-5 w-5 text-acid group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none">
          <path d="M4 8 Q12 2 20 8 Q12 14 4 8Z" fill="currentColor" opacity="0.9"/>
          <path d="M4 16 Q12 10 20 16 Q12 22 4 16Z" fill="currentColor" opacity="0.4"/>
        </svg>
        <span class="font-display text-lg tracking-wider text-[#e8e8e8]">BETTERSVG</span>
      </a>

      <div class="flex items-center gap-6">
        <span class="hidden sm:block font-mono text-xs text-acid border border-acid/30 rounded-none px-2 py-1">Docs</span>
        <a href="https://github.com/mhaadiabu/better-svg" target="_blank" class="text-sm text-zinc-muted hover:text-acid transition-colors">GitHub</a>
        <a href="https://www.npmjs.com/package/@mhaadi/svg" target="_blank" class="text-sm text-zinc-muted hover:text-acid transition-colors">npm</a>
      </div>
    </div>
  </nav>

  <!-- Mobile sidebar overlay -->
  <div id="docs-mobile-overlay" class="mobile-sidebar-overlay lg:hidden"></div>
  <div id="docs-mobile-panel" class="mobile-sidebar-panel lg:hidden">
    <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">Framework</p>
    <div class="px-3 mb-5">
      <FrameworkPicker
        frameworks={frameworks}
        initial="react"
        id="fw-picker-mobile"
      />
    </div>

    <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">On this page</p>
    <nav class="flex flex-col gap-0.5">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="sidebar-link mobile-sidebar-link" data-section={s.id}>
          {s.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="min-h-screen pt-13 lg:pt-16.25 overflow-x-clip">
    <!-- Mobile menu trigger (sticky) -->
    <button id="docs-mobile-sidebar-btn" class="lg:hidden sticky top-13 z-30 w-full flex items-center justify-between gap-2 border-b border-coal-2 bg-coal/95 backdrop-blur-md px-4 py-2.5 text-xs font-mono text-zinc-muted hover:text-acid transition-colors">
      <span class="flex items-center gap-2 min-w-0">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="shrink-0">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        <span class="truncate">
          <span id="docs-mobile-current-fw" class="text-acid">React</span>
          <span class="text-zinc-muted"> · </span>
          <span data-mobile-section>Overview</span>
        </span>
      </span>
      <svg id="docs-mobile-sidebar-chevron" class="transition-transform shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </button>
    <!-- LEFT SIDEBAR (fixed) -->
    <aside class="hidden lg:block fixed left-0 top-16.25 bottom-0 w-60 overflow-y-auto border-r border-coal-2 py-8 pr-4">
      <div class="mx-auto max-w-7xl px-4 flex flex-col h-full">
        <div>
          <div class="mb-6">
            <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">@mhaadi/svg</p>
            <p class="px-3 text-xs text-zinc-muted">API Reference</p>
          </div>

          <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">Framework</p>
          <div class="px-3 mb-6">
            <FrameworkPicker
              frameworks={frameworks}
              initial="react"
              id="fw-picker-desktop"
            />
          </div>

          <!-- Version badge -->
          <div class="mt-8 mx-3 rounded-none border border-coal-4 bg-coal-1 p-3">
            <p class="font-mono text-[10px] text-[#3a3a3a] mb-1">CURRENT VERSION</p>
            <p class="font-mono text-sm text-acid">v0.1.1</p>
          </div>
        </div>
      </div>
    </aside>

    <!-- CONTENT (with left/right sidebar offsets) -->
    <div class="lg:pl-60 lg:pr-48">
      <main class="min-w-0 max-w-4xl mx-auto px-4 lg:px-10 py-8 lg:py-12">

          <!-- Page header -->
          <div class="mb-10 lg:mb-16 pb-8 border-b border-coal-2">
            <div class="mb-3 flex items-center gap-2 font-mono text-xs text-zinc-muted">
              <span>BetterSVG</span>
              <span class="text-coal-4">/</span>
              <span class="text-acid">API Reference</span>
            </div>
            <h1 class="font-display text-6xl tracking-wider text-[#e8e8e8] leading-none mb-4">DOCS</h1>
            <p class="text-zinc-muted max-w-xl leading-relaxed">
              Complete reference for the <code class="rounded-none bg-coal-2 px-1.5 py-0.5 font-mono text-xs text-[#e8e8e8]">{"<SVG>"}</code> /
              <code class="rounded-none bg-coal-2 px-1.5 py-0.5 font-mono text-xs text-[#e8e8e8]">Svg</code> component.
              Resolves, sanitizes, and renders SVGs inline — from any source, in
              React, React Native, Vue, Svelte, or Flutter.
            </p>
          </div>

          <!-- OVERVIEW -->
          <section id="overview" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Overview</h2>
            <p class="docs-body">
              <code class="inline-code">@mhaadi/svg</code> exposes a single component —{" "}
              <code class="inline-code">{"<SVG>"}</code> — that resolves SVG content from four source types
              (inline markup, <code class="inline-code">data:</code> URIs, remote URLs, or a local{" "}
              <code class="inline-code">name</code>), sanitizes unsafe content, and renders a true{" "}
              <code class="inline-code">{"<svg>"}</code> element with full prop forwarding. Available for
              <strong class="text-[#e8e8e8]"> React, React Native, Vue, Svelte</strong> via subpath exports
              on a single npm package, and for <strong class="text-[#e8e8e8]">Flutter</strong> via the
              separate <code class="inline-code">svg_flutter</code> pub package. No{" "}
              <code class="inline-code">{"<img>"}</code> wrappers. No restrictions.
            </p>

            <div class="mt-6 grid sm:grid-cols-4 gap-4">
              {[
                { label: "Zero dependencies" },
                { label: "TypeScript-first" },
                { label: "Sanitized by default" },
                { label: "5 frameworks" },
              ].map((badge) => (
                <div class="flex items-center gap-2 rounded-none border border-coal-4 bg-coal-1 px-4 py-3">
                  <span class="text-acid text-xs">⬡</span>
                  <span class="font-mono text-xs text-zinc-muted">{badge.label}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- INSTALLATION -->
          <section id="installation" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Installation</h2>
            <p class="docs-body">Install the right package for your framework:</p>

            <div class="mt-6 space-y-6">
              <!-- React / RN / Vue / Svelte (one package) -->
              <div data-fw-show="react react-native vue svelte">
                <p class="mb-3 text-sm text-[#e8e8e8] font-semibold">JS/TS — React, React Native, Vue, Svelte</p>
                <div class="space-y-3">
                  {[
                    { pm: "pnpm", cmd: "pnpm add @mhaadi/svg" },
                    { pm: "npm", cmd: "npm install @mhaadi/svg" },
                    { pm: "yarn", cmd: "yarn add @mhaadi/svg" },
                    { pm: "bun", cmd: "bun add @mhaadi/svg" },
                  ].map((pkg) => (
                    <div class="code-block" data-lang={pkg.pm}>
                      <pre class="px-4 py-3 text-sm text-[#e8e8e8]">{pkg.cmd}</pre>
                    </div>
                  ))}
                </div>
                <div class="mt-3 rounded-none border border-coal-4 bg-coal-1 p-4">
                  <p class="font-mono text-xs text-zinc-muted">
                    <span class="text-acid">Peer (React):</span> React 18+ · TypeScript 5+ (optional)
                  </p>
                  <p class="font-mono text-xs text-zinc-muted mt-1">
                    <span class="text-acid">Peer (RN):</span> react-native, react-native-svg
                  </p>
                </div>
              </div>

              <!-- Flutter -->
              <div data-fw-show="flutter" class="hidden">
                <p class="mb-3 text-sm text-[#e8e8e8] font-semibold">Flutter</p>
                <div class="code-block" data-lang="sh">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]">flutter pub add svg_flutter</pre>
                </div>
                <p class="mt-3 text-sm text-zinc-muted">Or add to <code class="inline-code">pubspec.yaml</code>:</p>
                <div class="code-block mt-3" data-lang="yaml">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]">dependencies:
  svg_flutter: ^0.1.0
  flutter_svg: ^2.0.10</pre>
                </div>
                <div class="mt-3 rounded-none border border-coal-4 bg-coal-1 p-4">
                  <p class="font-mono text-xs text-zinc-muted">
                    <span class="text-acid">Requires:</span> Flutter 3.22+ · Dart 3.4+ · flutter_svg 2.x
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- USAGE -->
          <section id="usage" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Usage</h2>
            <p class="docs-body">Import the component from the entry point that matches your framework:</p>

            <!-- React -->
            <div data-fw-show="react">
              <div class="mt-4 code-block" data-lang="tsx">
                <pre class="p-5 text-sm leading-7"><span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/react"</span><span class="token-punct">;</span>

<span class="token-comment">{"// From a local name (resolves from src/assets/svg, app/assets/svg, or public/assets/svg)"}</span>
<span class="token-keyword">export</span> <span class="token-keyword">function</span> <span class="token-component">MyComponent</span><span class="token-punct">()</span> <span class="token-punct">{"{"}</span>
  <span class="token-keyword">return</span> <span class="token-punct">{"("}</span>
    <span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
      <span class="token-prop">name</span><span class="token-punct">=</span><span class="token-string">"logo"</span>
      <span class="token-prop">className</span><span class="token-punct">=</span><span class="token-string">"h-6 w-6 text-current"</span>
      <span class="token-prop">aria-label</span><span class="token-punct">=</span><span class="token-string">"Logo"</span>
    <span class="token-punct">{"/>"}</span>
  <span class="token-punct">{")"}</span><span class="token-punct">;</span>
<span class="token-punct">{"}"}</span></pre>
              </div>

              <div class="mt-6 code-block" data-lang="tsx">
                <pre class="p-5 text-sm leading-7"><span class="token-comment">{"// From a remote URL with loading and fallback states"}</span>
<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
  <span class="token-prop">sanitize</span>
  <span class="token-prop">loading</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-punct">{"<"}</span><span class="token-component">Spinner</span> <span class="token-punct">{"/>"}</span><span class="token-punct">{"}"}</span>
  <span class="token-prop">fallback</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-punct">{"<"}</span><span class="token-component">FallbackIcon</span> <span class="token-punct">{"/>"}</span><span class="token-punct">{"}"}</span>
  <span class="token-prop">onSvgLoad</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-punct">(</span>markup<span class="token-punct">)</span> <span class="token-punct">{"=>"}</span> console<span class="token-punct">.</span>log<span class="token-punct">(</span>markup<span class="token-punct">)</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"/>"}</span></pre>
              </div>

              <div class="mt-6 code-block" data-lang="tsx">
                <pre class="p-5 text-sm leading-7"><span class="token-comment">{"// From an inline SVG string"}</span>
<span class="token-keyword">const</span> LOGO <span class="token-punct">=</span> <span class="token-string">{"`<svg viewBox='0 0 24 24'>...</svg>`"}</span><span class="token-punct">;</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span>LOGO<span class="token-punct">{"}"}</span>
  <span class="token-prop">className</span><span class="token-punct">=</span><span class="token-string">"h-8 w-8 text-emerald-400"</span>
<span class="token-punct">{"/>"}</span></pre>
              </div>
            </div>

            <!-- React Native -->
            <div data-fw-show="react-native" class="hidden">
              <div class="mt-4 code-block" data-lang="tsx">
                <pre class="p-5 text-sm leading-7"><span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/react-native"</span><span class="token-punct">;</span>

<span class="token-keyword">export</span> <span class="token-keyword">function</span> <span class="token-component">MyIcon</span><span class="token-punct">()</span> <span class="token-punct">{"{"}</span>
  <span class="token-keyword">return</span> <span class="token-punct">{"("}</span>
    <span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
      <span class="token-prop">name</span><span class="token-punct">=</span><span class="token-string">"logo"</span>
      <span class="token-prop">width</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">24</span><span class="token-punct">{"}"}</span>
      <span class="token-prop">height</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-string">24</span><span class="token-punct">{"}"}</span>
      <span class="token-prop">color</span><span class="token-punct">=</span><span class="token-string">"#111827"</span>
    <span class="token-punct">{"/>"}</span>
  <span class="token-punct">{")"}</span><span class="token-punct">;</span>
<span class="token-punct">{"}"}</span></pre>
              </div>

              <p class="docs-body mt-6">
                The renderer parses the SVG into an AST and emits a{" "}
                <code class="inline-code">react-native-svg</code> tree. Supported nodes:{" "}
                <code class="inline-code">Svg</code>, <code class="inline-code">Path</code>,{" "}
                <code class="inline-code">Rect</code>, <code class="inline-code">Circle</code>,{" "}
                <code class="inline-code">Ellipse</code>, <code class="inline-code">Line</code>,{" "}
                <code class="inline-code">Polyline</code>, <code class="inline-code">Polygon</code>,{" "}
                <code class="inline-code">Text</code>, gradients,{" "}
                <code class="inline-code">ClipPath</code>, <code class="inline-code">Mask</code>,{" "}
                <code class="inline-code">Defs</code>, <code class="inline-code">Use</code>,{" "}
                <code class="inline-code">Symbol</code>, <code class="inline-code">Image</code>. Inline{" "}
                <code class="inline-code">style</code> and <code class="inline-code">class</code> are
                translated into React Native style objects.
              </p>
            </div>

            <!-- Vue -->
            <div data-fw-show="vue" class="hidden">
              <div class="mt-4 code-block" data-lang="vue">
                <pre class="p-5 text-sm leading-7"><span class="token-punct">{"<"}</span><span class="token-keyword">script</span> <span class="token-prop">setup</span> <span class="token-prop">lang</span><span class="token-punct">=</span><span class="token-string">"ts"</span><span class="token-punct">{">"}</span>
  <span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/vue"</span><span class="token-punct">;</span>
<span class="token-punct">{"</"}</span><span class="token-keyword">script</span><span class="token-punct">{">"}</span>

<span class="token-punct">{"<"}</span><span class="token-component">template</span><span class="token-punct">{">"}</span>
  <span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
    <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
    <span class="token-prop">:width</span><span class="token-punct">=</span><span class="token-string">24</span>
    <span class="token-prop">:height</span><span class="token-punct">=</span><span class="token-string">24</span>
    <span class="token-prop">class</span><span class="token-punct">=</span><span class="token-string">"h-6 w-6 text-current"</span>
  <span class="token-punct">{"/>"}</span>

  <span class="token-punct">{"<"}</span><span class="token-component">SVG</span> <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"/icon.svg"</span><span class="token-punct">{">"}</span>
    <span class="token-punct">{"<"}</span><span class="token-keyword">template</span> <span class="token-prop">#loading</span><span class="token-punct">{">"}</span>Loading…<span class="token-punct">{"</"}</span><span class="token-keyword">template</span><span class="token-punct">{">"}</span>
    <span class="token-punct">{"<"}</span><span class="token-keyword">template</span> <span class="token-prop">#fallback</span><span class="token-punct">{">"}</span>Failed<span class="token-punct">{"</"}</span><span class="token-keyword">template</span><span class="token-punct">{">"}</span>
  <span class="token-punct">{"</"}</span><span class="token-component">SVG</span><span class="token-punct">{">"}</span>
<span class="token-punct">{"</"}</span><span class="token-component">template</span><span class="token-punct">{">"}</span></pre>
              </div>
              <p class="docs-body mt-4">
                Loading and fallback are exposed as named slots. <code class="inline-code">svg-load</code> and{" "}
                <code class="inline-code">svg-error</code> events are emitted when the markup resolves or fails.
              </p>
            </div>

            <!-- Svelte -->
            <div data-fw-show="svelte" class="hidden">
              <div class="mt-4 code-block" data-lang="svelte">
                <pre class="p-5 text-sm leading-7"><span class="token-punct">{"<"}</span><span class="token-keyword">script</span> <span class="token-prop">lang</span><span class="token-punct">=</span><span class="token-string">"ts"</span><span class="token-punct">{">"}</span>
  <span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/svelte"</span><span class="token-punct">;</span>
<span class="token-punct">{"</"}</span><span class="token-keyword">script</span><span class="token-punct">{">"}</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://cdn.example.com/icon.svg"</span>
  <span class="token-prop">width</span><span class="token-punct">=</span><span class="token-string">"24"</span>
  <span class="token-prop">height</span><span class="token-punct">=</span><span class="token-string">"24"</span>
<span class="token-punct">{"/>"}</span>

<span class="token-punct">{"<"}</span><span class="token-component">SVG</span> <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"/icon.svg"</span><span class="token-punct">{">"}</span>
  <span class="token-punct">{"{#"}</span><span class="token-keyword">snippet</span> loading<span class="token-punct">(){"}"}</span>Loading…<span class="token-punct">{"{/"}</span><span class="token-keyword">snippet</span><span class="token-punct">{"}"}</span>
  <span class="token-punct">{"{#"}</span><span class="token-keyword">snippet</span> fallback<span class="token-punct">(){"}"}</span>Failed<span class="token-punct">{"{/"}</span><span class="token-keyword">snippet</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"</"}</span><span class="token-component">SVG</span><span class="token-punct">{">"}</span></pre>
              </div>
              <p class="docs-body mt-4">
                Svelte 5 uses the runes API. Pass <code class="inline-code">loading</code> and{" "}
                <code class="inline-code">fallback</code> as snippets.
              </p>
            </div>

            <!-- Flutter -->
            <div data-fw-show="flutter" class="hidden">
