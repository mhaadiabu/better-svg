          <!-- SOURCE TYPES -->
          <section id="source-types" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Source Types</h2>
            <p class="docs-body">The component resolves SVG content from four source types, checked in this order:</p>

            <div class="mt-6 space-y-4">
              <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                <div class="flex items-start gap-4">
                  <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-none border border-acid/30 font-display text-base text-acid">1</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="mb-1 font-semibold text-[#e8e8e8]">Inline SVG markup</h3>
                    <p class="text-sm text-zinc-muted">A raw SVG string starting with <code class="inline-code">{"<svg"}</code> or <code class="inline-code">{"<?xml"}</code>. Parsed by DOMParser, sanitized, then inlined.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                <div class="flex items-start gap-4">
                  <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-none border border-coal-4 font-display text-base text-zinc-muted">2</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="mb-1 font-semibold text-[#e8e8e8]">data: URI</h3>
                    <p class="text-sm text-zinc-muted">A <code class="inline-code">data:image/svg+xml,…</code> or base64-encoded data URL. Decoded and inlined.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                <div class="flex items-start gap-4">
                  <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-none border border-coal-4 font-display text-base text-zinc-muted">3</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="mb-1 font-semibold text-[#e8e8e8]">Remote URL</h3>
                    <p class="text-sm text-zinc-muted">Any <code class="inline-code">https://</code> URL. Fetched, parsed, cached in memory by URL, then inlined.</p>
                  </div>
                </div>
              </div>

              <div class="rounded-none border border-acid/20 bg-acid/5 p-5">
                <div class="flex items-start gap-4">
                  <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-none border border-acid/40 font-display text-base text-acid">★</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="mb-1 font-semibold text-[#e8e8e8]">Local name (via <code class="inline-code text-sm">name</code> prop)</h3>
                    <p class="text-sm text-zinc-muted mb-2">
                      No path or URL needed. Provide a filename without extension.
                    </p>
                    <ul class="text-sm text-zinc-muted space-y-1 list-disc pl-5">
                      <li>JS — Vite/CRA/Next: resolved at build time from <code class="inline-code">src/assets/svg/</code> or <code class="inline-code">app/assets/svg/</code>, else fetched from <code class="inline-code">/assets/svg/{"{name}"}.svg</code>.</li>
                      <li>Flutter: resolved at runtime via the <code class="inline-code">localResolver</code> callback, else defaults to <code class="inline-code">assets/svg/{"{name}"}.svg</code>.</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- SECURITY -->
          <section id="security" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Security</h2>
            <p class="docs-body">
              Sanitization is <strong class="text-[#e8e8e8]">enabled by default</strong> (<code class="inline-code">sanitize=true</code>).
              When active, the following are stripped from every SVG before rendering:
            </p>

            <div class="mt-6 grid sm:grid-cols-2 gap-3">
              {strippedElements.map((item) => (
                <div class="flex items-start gap-3 rounded-none border border-coal-4 bg-coal-1 px-4 py-3">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-acid" viewBox="0 0 16 16" fill="none">
                    <path d="M8 14s5.333-2.667 5.333-6.667V3.333L8 1.333 2.667 3.333v4C2.667 11.333 8 14 8 14z" stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                  <div>
                    <code class="font-mono text-xs text-[#e8e8e8]">{item.elem}</code>
                    <p class="mt-0.5 text-xs text-zinc-muted">{item.reason}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-6 rounded-none border border-amber-900/40 bg-amber-950/20 p-4">
              <div class="flex gap-3">
                <span class="mt-0.5 text-amber-400">⚠</span>
                <div>
                  <p class="text-sm font-semibold text-amber-400 mb-1">When to disable sanitization</p>
                  <p class="text-sm text-zinc-muted">
                    Only set <code class="inline-code">sanitize=false</code> when you <strong class="text-[#e8e8e8]">fully trust and control</strong> the SVG source.
                    Never disable sanitization for user-generated content, third-party CDNs, or any untrusted input.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- EDGE CASES -->
          <section id="edge-cases" class="mb-16 scroll-mt-24">
            <h2 class="docs-heading">Edge Cases</h2>

            <div class="mt-4 space-y-6">
              <div>
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">Server-side rendering (React)</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  DOM parsing is unavailable on the server. Use the <code class="inline-code">loading</code> prop to render a placeholder during SSR — otherwise the component renders nothing on the first pass.
                </p>
                <div class="code-block" data-lang="tsx">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]"><span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span>remoteUrl<span class="token-punct">{"}"}</span>
  <span class="token-prop">loading</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-punct">{"<"}</span><span class="token-component">div</span> <span class="token-prop">className</span><span class="token-punct">=</span><span class="token-string">"h-6 w-6 bg-zinc-800 rounded animate-pulse"</span> <span class="token-punct">{"/>"}</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"/>"}</span></pre>
                </div>
              </div>

              <div>
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">Remote SVGs & CORS</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  Remote SVGs require the server to send appropriate CORS headers. Use <code class="inline-code">fetchOptions</code> to pass credentials or custom headers.
                </p>
                <div class="code-block" data-lang="tsx">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]"><span class="token-punct">{"<"}</span><span class="token-component">SVG</span>
  <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-string">"https://api.example.com/icon.svg"</span>
  <span class="token-prop">fetchOptions</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span>useMemo<span class="token-punct">(</span><span class="token-punct">()</span> <span class="token-punct">{"=>"}</span> <span class="token-punct">({"{"}</span>
    headers<span class="token-punct">:</span> <span class="token-punct">{"{"}</span> Authorization<span class="token-punct">:</span> <span class="token-string">"Bearer token"</span> <span class="token-punct">{"}"}</span><span class="token-punct">,</span>
    credentials<span class="token-punct">:</span> <span class="token-string">"include"</span><span class="token-punct">,</span>
  <span class="token-punct">{"}"}</span><span class="token-punct">),</span> <span class="token-punct">[]</span><span class="token-punct">)</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"/>"}</span></pre>
                </div>
              </div>

              <div>
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">Memoize fetchOptions (React/Vue/Svelte)</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  <code class="inline-code">fetchOptions</code> should be stable across renders — memoize it to prevent unnecessary re-fetches.
                </p>
                <div class="code-block" data-lang="tsx">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]"><span class="token-keyword">const</span> opts <span class="token-punct">=</span> useMemo<span class="token-punct">(</span>
  <span class="token-punct">()</span> <span class="token-punct">{"=>"}</span> <span class="token-punct">({"{"}</span> headers<span class="token-punct">:</span> <span class="token-punct">{"{"}</span> Accept<span class="token-punct">:</span> <span class="token-string">"image/svg+xml"</span> <span class="token-punct">{"}"}</span> <span class="token-punct">{"}"}</span><span class="token-punct">),</span>
  <span class="token-punct">[]</span>
<span class="token-punct">);</span>
<span class="token-punct">{"<"}</span><span class="token-component">SVG</span> <span class="token-prop">src</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span>url<span class="token-punct">{"}"}</span> <span class="token-prop">fetchOptions</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span>opts<span class="token-punct">{"}"}</span> <span class="token-punct">{"/>"}</span></pre>
                </div>
              </div>

              <div>
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">name prop fallback chain</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  The <code class="inline-code">name</code> prop looks for the file in <code class="inline-code">src/assets/svg/</code>, then <code class="inline-code">app/assets/svg/</code>, then <code class="inline-code">public/assets/svg/</code>. If not found anywhere, it falls back to <code class="inline-code">/assets/svg/{"{name}"}.svg</code> in public.
                </p>
                <div class="code-block" data-lang="tsx">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]"><span class="token-comment">{"// Expects file at one of:"}</span>
<span class="token-comment">{"// src/assets/svg/logo.svg"}</span>
<span class="token-comment">{"// app/assets/svg/logo.svg"}</span>
<span class="token-comment">{"// public/assets/svg/logo.svg"}</span>
<span class="token-punct">{"<"}</span><span class="token-component">SVG</span> <span class="token-prop">name</span><span class="token-punct">=</span><span class="token-string">"logo"</span> <span class="token-punct">{"/>"}</span></pre>
                </div>
              </div>

              <div data-fw-show="flutter" class="hidden">
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">Custom HTTP client (Flutter)</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  Inject your own <code class="inline-code">http.Client</code> for testing or to share a connection pool. The widget takes ownership of the client lifecycle unless you supply your own.
                </p>
                <div class="code-block" data-lang="dart">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]">Svg(
  src: 'https://example.com/icon.svg',
  httpClient: myClient,
)</pre>
                </div>
              </div>

              <div data-fw-show="flutter" class="hidden">
                <h3 class="mb-2 font-semibold text-[#e8e8e8]">Local asset resolver (Flutter)</h3>
                <p class="mb-3 text-sm text-zinc-muted leading-relaxed">
                  By default, <code class="inline-code">name</code> falls back to <code class="inline-code">assets/svg/{"{name}"}.svg</code>. Pass a custom <code class="inline-code">localResolver</code> to integrate with <code class="inline-code">rootBundle</code> or your own asset pipeline.
                </p>
                <div class="code-block" data-lang="dart">
                  <pre class="px-4 py-3 text-sm text-[#e8e8e8]">Svg(
  name: 'logo',
  localResolver: (name) async => rootBundle.loadString('assets/icons/$name.svg'),
)</pre>
                </div>
              </div>
            </div>
          </section>

