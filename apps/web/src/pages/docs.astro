<style>
  .docs-heading {
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 2.5rem;
    letter-spacing: 0.05em;
    color: #e8e8e8;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .docs-body {
    color: var(--color-zinc-muted);
    line-height: 1.625;
  }
  .inline-code {
    border-radius: 0;
    background: #1a1a1a;
    padding: 0.125rem 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1rem;
    color: #e8e8e8;
  }
</style>

<script>
  let cleanup = () => {};

  function initDocsPage() {
    cleanup();

    // Framework switching is handled by FrameworkPicker.astro (which
    // imports the data and wires the `data-fw-show` toggling itself).
    // We only handle scroll-spy + mobile sidebar here.

    // ── Active sidebar highlight on scroll ────────────────────────
    const sectionEls = document.querySelectorAll("section[id]");
    const sidebarLinks = document.querySelectorAll(".sidebar-link");
    const sectionLabels: Record<string, string> = {};
    sidebarLinks.forEach((a) => {
      const id = a.getAttribute("data-section") || a.getAttribute("data-toc");
      if (id) sectionLabels[id] = a.textContent?.trim() ?? id;
    });

    // ── Mobile sidebar (declare before use to avoid TDZ) ─────────
    const mobileSidebarBtn = document.getElementById("docs-mobile-sidebar-btn");
    const mobileOverlay = document.getElementById("docs-mobile-overlay");
    const mobilePanel = document.getElementById("docs-mobile-panel");
    const mobileChevron = document.getElementById("docs-mobile-sidebar-chevron");
    const mobileSection = mobileSidebarBtn?.querySelector("[data-mobile-section]");

    function updateActive() {
      let active = "";
      sectionEls.forEach((el) => {
        const top = (el as HTMLElement).offsetTop - 120;
        if (window.scrollY >= top) active = el.id;
      });
      sidebarLinks.forEach((a) => {
        const id = a.getAttribute("data-section") || a.getAttribute("data-toc");
        a.classList.toggle("active", id === active);
      });
      if (mobileSection) {
        mobileSection.textContent = sectionLabels[active] || "Overview";
      }
    }

    window.addEventListener("scroll", updateActive, { passive: true });
    updateActive();

    // ── Mobile sidebar ────────────────────────────────────────────
    function openMobileSidebar() {
      mobileOverlay?.classList.add("open");
      mobilePanel?.classList.add("open");
      document.body.style.overflow = "hidden";
      mobileChevron?.classList.add("rotate-180");
    }
    function closeMobileSidebar() {
      mobileOverlay?.classList.remove("open");
      mobilePanel?.classList.remove("open");
      document.body.style.overflow = "";
      mobileChevron?.classList.remove("rotate-180");
    }

    mobileSidebarBtn?.addEventListener("click", openMobileSidebar);
    mobileOverlay?.addEventListener("click", closeMobileSidebar);
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-sidebar-link"));
    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMobileSidebar);
    });

    // ── Code blocks: header, copy & wrap buttons ──────────────────
    function initCodeBlocks() {
      document.querySelectorAll(".code-block").forEach((block) => {
        if (block.querySelector(".code-block-header")) return;

        block.classList.add("has-header");

        const lang = block.getAttribute("data-lang") || "";

        const header = document.createElement("div");
        header.className = "code-block-header";

        const langEl = document.createElement("span");
        langEl.className = "code-block-lang";
        langEl.textContent = lang;
        header.appendChild(langEl);

        const actions = document.createElement("div");
        actions.className = "code-block-actions";

        const wrapBtn = document.createElement("button");
        wrapBtn.className = "wrap-btn";
        wrapBtn.setAttribute("aria-label", "Toggle word wrap");
        wrapBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M4 12h10M4 17h6"/><path d="M16 17l3-3-3-3" stroke-width="1.5"/></svg> Wrap`;
        wrapBtn.addEventListener("click", () => {
          const body = block.querySelector(".code-block-body");
          if (body) {
            body.classList.toggle("is-wrapped");
            const on = body.classList.contains("is-wrapped");
            wrapBtn.innerHTML = on
              ? `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M4 12h10M4 17h6"/><path d="M14 14l3 3 3-3" stroke-width="1.5"/></svg> Unwrap`
              : `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M4 12h10M4 17h6"/><path d="M16 17l3-3-3-3" stroke-width="1.5"/></svg> Wrap`;
          }
        });
        actions.appendChild(wrapBtn);

        const copyBtn = document.createElement("button");
        copyBtn.className = "copy-btn";
        copyBtn.setAttribute("aria-label", "Copy code");
        copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy`;
        copyBtn.addEventListener("click", () => {
          const pre = block.querySelector("pre");
          if (!pre) return;
          const text = pre.textContent || "";
          navigator.clipboard.writeText(text.replace(/^\$\s*/, "")).then(() => {
            copyBtn.classList.add("copied");
            copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied`;
            setTimeout(() => {
              copyBtn.classList.remove("copied");
              copyBtn.innerHTML = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy`;
            }, 2000);
          });
        });
        actions.appendChild(copyBtn);

        header.appendChild(actions);

        const pre = block.querySelector("pre");
        if (pre?.parentNode) {
          pre.classList.remove("overflow-x-auto");
          pre.style.overflowX = "";
          const body = document.createElement("div");
          body.className = "code-block-body";
          pre.parentNode.insertBefore(body, pre);
          body.appendChild(pre);
        }

        block.insertBefore(header, block.firstChild);

        const bodyEl = block.querySelector(".code-block-body");
        if (bodyEl) {
          const checkWrap = () => {
            if (!bodyEl.classList.contains("is-wrapped")) {
              if (bodyEl.scrollWidth > bodyEl.clientWidth + 1) {
                block.classList.add("has-wrap");
              } else {
                block.classList.remove("has-wrap");
              }
            }
          };
          requestAnimationFrame(checkWrap);
          const ro = new ResizeObserver(checkWrap);
          ro.observe(bodyEl);
        }
      });
    }
    initCodeBlocks();

    cleanup = () => {
      window.removeEventListener("scroll", updateActive);
      mobileSidebarBtn?.removeEventListener("click", openMobileSidebar);
      mobileOverlay?.removeEventListener("click", closeMobileSidebar);
      mobileLinks.forEach((link) => {
        link.removeEventListener("click", closeMobileSidebar);
      });
    };
  }

  document.addEventListener("astro:page-load", initDocsPage);
  document.addEventListener("astro:before-swap", () => cleanup());
  initDocsPage();
</script>
