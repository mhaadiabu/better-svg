{
  "$schema": "https://v2-9-18.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "cache": false,
      "env": [
        "CLOUDFLARE_API_TOKEN",
        "CLOUDFLARE_API_KEY",
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_EMAIL",
        "ALCHEMY_STATE_TOKEN",
        "ALCHEMY_CI_STATE_STORE_CHECK",
        "ALCHEMY_PROFILE",
        "CLOUDFLARE_PROFILE",
        "VITE_SERVER_URL"
      ]
    },
    "destroy": {
      "cache": false
    }
  }
}
