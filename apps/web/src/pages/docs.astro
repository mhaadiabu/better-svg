  <span class="token-punct">{"<"}</span><span class="token-keyword">template</span> <span class="token-prop">#fallback</span><span class="token-punct">{">"}</span><span class="token-component">Fallback</span><span class="token-punct">{"</"}</span><span class="token-keyword">template</span><span class="token-punct">{">"}</span>
<span class="token-punct">{"</"}</span><span class="token-component">SVG</span><span class="token-punct">{">"}</span></pre>
