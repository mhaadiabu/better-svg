                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">src</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">string</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
