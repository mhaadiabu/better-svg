<span class="token-keyword">class</span> <span class="token-component">MyIcon</span> <span class="token-keyword">extends</span> <span class="token-component">StatelessWidget</span> <span class="token-punct">{"{"}</span>
  <span class="token-keyword">const</span> <span class="token-component">MyIcon</span><span class="token-punct">({"{"}</span><span class="token-keyword">super</span><span class="token-punct">.</span>key<span class="token-punct">{"}"});</span>

  <span class="token-keyword">@override</span>
  <span class="token-component">Widget</span> <span class="token-prop">build</span><span class="token-punct">(</span><span class="token-component">BuildContext</span> context<span class="token-punct">)</span> <span class="token-punct">{"{"}</span>
    <span class="token-keyword">return</span> <span class="token-keyword">const</span> <span class="token-component">Svg</span><span class="token-punct">(</span>
      <span class="token-prop">src</span><span class="token-punct">:</span> <span class="token-string">'https://cdn.example.com/icon.svg'</span><span class="token-punct">,</span>
      <span class="token-prop">width</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
      <span class="token-prop">height</span><span class="token-punct">:</span> <span class="token-string">24</span><span class="token-punct">,</span>
      <span class="token-prop">color</span><span class="token-punct">:</span> <span class="token-component">Color</span><span class="token-punct">(</span><span class="token-string">0xFF111827</span><span class="token-punct">),</span>
      <span class="token-prop">loading</span><span class="token-punct">:</span> <span class="token-component">CircularProgressIndicator</span><span class="token-punct">(),</span>
      <span class="token-prop">fallback</span><span class="token-punct">:</span> <span class="token-component">Icon</span><span class="token-punct">(</span><span class="token-component">Icons</span><span class="token-punct">.</span>broken_image<span class="token-punct">),</span>
    <span class="token-punct">);</span>
