---
import Base from "../layouts/Base.astro";
import FrameworkPicker from "../components/FrameworkPicker.astro";
import { frameworks } from "../data/frameworks";
import svgPkg from "../../../../packages/svg/package.json";

const version = svgPkg.version;

const sections = [
  { id: "overview", label: "Overview" },
  { id: "installation", label: "Installation" },
  { id: "usage", label: "Usage" },
  { id: "props", label: "Props" },
  { id: "framework-specifics", label: "Framework Specifics" },
  { id: "source-types", label: "Source Types" },
  { id: "security", label: "Security" },
  { id: "edge-cases", label: "Edge Cases" },
  { id: "examples", label: "Examples" },
];

const strippedElements = [
  { elem: "<script>", reason: "Arbitrary JS execution" },
  { elem: "<foreignObject>", reason: "Embedded HTML injection" },
  { elem: "<iframe>", reason: "External frame embedding" },
  { elem: "<object>", reason: "Plugin execution vector" },
  { elem: "<embed>", reason: "Plugin execution vector" },
  { elem: "on* attributes", reason: "Inline event handler XSS" },
  { elem: "unsafe href", reason: "javascript: URL injection" },
  { elem: "unsafe xlink:href", reason: "XLink javascript: URLs" },
];

import CodeBlock from "../components/CodeBlock.astro";
import PmTabs from "../components/PmTabs.astro";
---


<Base
  title="Docs — BetterSVG"
  description="Full API reference for @mhaadi/svg and svg_flutter — the inline SVG components for React, React Native, Vue, Svelte, and Flutter."
>
  <!-- NAV -->
  <nav class="sticky top-0 left-0 right-0 z-50 border-b border-coal-2 bg-coal/90 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 lg:px-4 py-3 lg:py-4">
      <a href="/" class="flex items-center gap-2.5 group">
        <svg class="h-5 w-5 text-acid group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none">
          <path d="M4 8 Q12 2 20 8 Q12 14 4 8Z" fill="currentColor" opacity="0.9"/>
          <path d="M4 16 Q12 10 20 16 Q12 22 4 16Z" fill="currentColor" opacity="0.4"/>
        </svg>
        <span class="font-display text-lg tracking-wider text-[#e8e8e8]">BETTERSVG</span>
      </a>

      <div class="flex items-center gap-4 md:gap-6">
        <div class="relative hidden md:block">
          <input
            id="docs-search"
            type="search"
            placeholder="Search docs..."
            class="w-48 lg:w-64 border border-coal-4 bg-coal-1 px-3 py-1.5 text-xs font-mono text-[#e8e8e8] placeholder:text-zinc-muted focus:border-acid focus:outline-none transition-colors"
            aria-label="Search documentation"
            autocomplete="off"
          />
          <div id="docs-search-results" class="absolute right-0 top-full mt-2 w-72 border border-coal-4 bg-coal-1 shadow-xl hidden" role="listbox" aria-label="Search results"></div>
        </div>
        <span class="hidden sm:block font-mono text-xs text-acid border border-acid/30 rounded-none px-2 py-1">Docs</span>
        <a href="https://github.com/mhaadiabu/better-svg" target="_blank" class="text-sm text-zinc-muted hover:text-acid transition-colors">GitHub</a>
        <a href="https://www.npmjs.com/package/@mhaadi/svg" target="_blank" class="text-sm text-zinc-muted hover:text-acid transition-colors">npm</a>
      </div>
    </div>
  </nav>

  <!-- Mobile sidebar overlay -->
  <div id="docs-mobile-overlay" class="mobile-sidebar-overlay lg:hidden"></div>
  <div id="docs-mobile-panel" class="mobile-sidebar-panel lg:hidden" role="dialog" aria-modal="true" aria-label="Docs menu" tabindex="-1">
    <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">Framework</p>
    <div class="px-3 mb-5">
      <FrameworkPicker
        frameworks={frameworks}
        initial="react"
        id="fw-picker-mobile"
      />
    </div>

    <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">On this page</p>
    <nav class="flex flex-col gap-0.5">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="sidebar-link mobile-sidebar-link" data-section={s.id}>
          {s.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="min-h-screen overflow-x-clip">
    <!-- Mobile menu trigger (sticky) -->
    <button id="docs-mobile-sidebar-btn" class="lg:hidden sticky top-13 z-30 w-full flex items-center justify-between gap-2 border-b border-coal-2 bg-coal/95 backdrop-blur-md px-4 py-2.5 text-xs font-mono text-zinc-muted hover:text-acid transition-colors">
      <span class="flex items-center gap-2 min-w-0">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="shrink-0">
          <line x1="8" y1="6" x2="21" y2="6"/>
          <line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/>
          <line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        <span class="truncate">
          <span id="docs-mobile-current-fw" class="text-acid">React</span>
          <span class="text-zinc-muted"> · </span>
          <span data-mobile-section>Overview</span>
        </span>
      </span>
      <svg id="docs-mobile-sidebar-chevron" class="transition-transform shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </button>
    <!-- LEFT SIDEBAR (fixed) -->
    <aside class="hidden lg:block fixed left-0 top-16.25 bottom-0 w-60 overflow-y-auto border-r border-coal-2 py-8 pr-4">
      <div class="mx-auto max-w-7xl px-4 flex flex-col h-full">
        <div>
          <div class="mb-6">
            <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">@mhaadi/svg</p>
            <p class="px-3 text-xs text-zinc-muted">API Reference</p>
          </div>

          <p class="px-3 mb-2 font-mono text-[10px] tracking-widest text-[#3a3a3a] uppercase">Framework</p>
          <div class="px-3 mb-6">
            <FrameworkPicker
              frameworks={frameworks}
              initial="react"
              id="fw-picker-desktop"
            />
          </div>

          <!-- Version badge -->
          <div class="mt-8 mx-3 rounded-none border border-coal-4 bg-coal-1 p-3">
            <p class="font-mono text-[10px] text-[#3a3a3a] mb-1">CURRENT VERSION</p>
            <p class="font-mono text-sm text-acid">v{version}</p>
          </div>
        </div>
      </div>
    </aside>

    <!-- CONTENT (with left/right sidebar offsets) -->
    <div class="lg:pl-60 lg:pr-48">
      <main id="main-content" class="min-w-0 max-w-4xl mx-auto px-4 lg:px-10 py-8 lg:py-12">

          <!-- Page header -->
          <div class="mb-10 lg:mb-16 pb-8 border-b border-coal-2">
            <div class="mb-3 flex items-center gap-2 font-mono text-xs text-zinc-muted">
              <span>BetterSVG</span>
              <span class="text-coal-4">/</span>
              <span class="text-acid">API Reference</span>
            </div>
            <h1 class="font-display text-6xl tracking-wider text-[#e8e8e8] leading-none mb-4">DOCS</h1>
            <p class="text-zinc-muted max-w-xl leading-relaxed">
              Complete reference for the <code class="rounded-none bg-coal-2 px-1.5 py-0.5 font-mono text-xs text-[#e8e8e8]">{"<SVG>"}</code> /
              <code class="rounded-none bg-coal-2 px-1.5 py-0.5 font-mono text-xs text-[#e8e8e8]">Svg</code> component.
              Resolves, sanitizes, and renders SVGs inline — from any source, in
              React, React Native, Vue, Svelte, or Flutter.
            </p>
          </div>

          <!-- OVERVIEW -->
          <section id="overview" class="mb-16">
            <h2 class="docs-heading">Overview</h2>
            <p class="docs-body">
              <code class="inline-code">@mhaadi/svg</code> exposes a single component —{" "}
              <code class="inline-code">{"<SVG>"}</code> — that resolves SVG content from any source,
              sanitizes unsafe markup, and renders it inline. On the web (React, Vue, Svelte) it renders a
              real <code class="inline-code">{"<svg>"}</code> DOM element; React Native renders a
              react-native-svg tree and Flutter renders via flutter_svg. Available for
              <strong class="text-[#e8e8e8]"> React, React Native, Vue, Svelte</strong> via subpath exports
              on a single npm package, and for <strong class="text-[#e8e8e8]">Flutter</strong> via the
              separate <code class="inline-code">svg_flutter</code> pub package. No{" "}
              <code class="inline-code">{"<img>"}</code> wrappers on the web adapters.
            </p>

            <div class="mt-6 grid sm:grid-cols-4 gap-4">
              {[
                { label: "Zero dependencies" },
                { label: "TypeScript-first" },
                { label: "Sanitized by default" },
                { label: "5 frameworks" },
              ].map((badge) => (
                <div class="flex items-center gap-2 rounded-none border border-coal-4 bg-coal-1 px-4 py-3">
                  <span class="text-acid text-xs">⬡</span>
                  <span class="font-mono text-xs text-zinc-muted">{badge.label}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- INSTALLATION -->
          <section id="installation" class="mb-16">
            <h2 class="docs-heading">Installation</h2>
            <p class="docs-body">Install the right package for your framework:</p>

            <div class="mt-6 space-y-6">
              <!-- React / RN / Vue / Svelte (one package) -->
              <div data-fw-show="react react-native vue svelte">
                <p class="mb-3 text-sm text-[#e8e8e8] font-semibold">JS/TS — React, React Native, Vue, Svelte</p>
                <PmTabs
                  commands={[
                    { pm: "pnpm", cmd: "pnpm add @mhaadi/svg" },
                    { pm: "npm", cmd: "npm install @mhaadi/svg" },
                    { pm: "yarn", cmd: "yarn add @mhaadi/svg" },
                    { pm: "bun", cmd: "bun add @mhaadi/svg" },
                  ]}
                />
                <div class="mt-3 rounded-none border border-coal-4 bg-coal-1 p-4">
                  <p class="font-mono text-xs text-zinc-muted">
                    <span class="text-acid">Peer (React):</span> React 18+ · TypeScript 5+ (optional)
                  </p>
                  <p class="font-mono text-xs text-zinc-muted mt-1">
                    <span class="text-acid">Peer (RN):</span> react-native, react-native-svg
                  </p>
                </div>
              </div>

              <!-- Flutter -->
              <div data-fw-show="flutter" class="hidden">
                <p class="mb-3 text-sm text-[#e8e8e8] font-semibold">Flutter</p>
                <div class="rounded-none border border-amber-900/40 bg-amber-950/20 p-4 mb-3">
                  <div class="flex gap-3">
                    <span class="mt-0.5 text-amber-400">⚠</span>
                    <div>
                      <p class="text-sm font-semibold text-amber-400 mb-1">Not yet published</p>
                      <p class="text-sm text-zinc-muted">
                        <code class="inline-code">svg_flutter</code> is not yet on pub.dev. The API below documents the intended interface — check back soon or follow the repo for the first release.
                      </p>
                    </div>
                  </div>
                </div>
                <div class="rounded-none border border-coal-4 bg-coal-1 p-4">
                  <p class="font-mono text-xs text-zinc-muted">
                    <span class="text-acid">Will require:</span> Flutter 3.22+ · Dart 3.4+ · flutter_svg 2.x
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- USAGE -->
          <section id="usage" class="mb-16">
            <h2 class="docs-heading">Usage</h2>
            <p class="docs-body">Import the component from the entry point that matches your framework:</p>

            <!-- React -->
            <div data-fw-show="react">
                              <CodeBlock code={`import { SVG } from "@mhaadi/svg/react";

// From a local name (resolves from src/assets/svg, app/assets/svg, or public/assets/svg)
export function MyComponent() {
  return (
    <SVG
      name="logo"
      className="h-6 w-6 text-current"
      aria-label="Logo"
    />
  );
}`} lang="tsx" />

                              <CodeBlock code={`// From a remote URL with loading and fallback states
<SVG
  src="https://cdn.example.com/icon.svg"
  sanitize
  loading={<Spinner />}
  fallback={<FallbackIcon />}
  onSvgLoad={(markup) => console.log(markup)}
/>`} lang="tsx" />

                              <CodeBlock code={`// From an inline SVG string
const LOGO = \`<svg viewBox='0 0 24 24'>...</svg>\`;

<SVG
  src={LOGO}
  className="h-8 w-8 text-emerald-400"
/>`} lang="tsx" />
            </div>

            <!-- React Native -->
            <div data-fw-show="react-native" class="hidden">
                              <CodeBlock code={`import { SVG } from "@mhaadi/svg/react-native";

export function MyIcon() {
  return (
    <SVG
      name="logo"
      width={24}
      height={24}
      color="#111827"
    />
  );
}`} lang="tsx" />

              <p class="docs-body mt-6">
                The renderer parses the SVG into an AST and emits a{" "}
                <code class="inline-code">react-native-svg</code> tree. Supported nodes:{" "}
                <code class="inline-code">Svg</code>, <code class="inline-code">Path</code>,{" "}
                <code class="inline-code">Rect</code>, <code class="inline-code">Circle</code>,{" "}
                <code class="inline-code">Ellipse</code>, <code class="inline-code">Line</code>,{" "}
                <code class="inline-code">Polyline</code>, <code class="inline-code">Polygon</code>,{" "}
                <code class="inline-code">Text</code>, gradients,{" "}
                <code class="inline-code">ClipPath</code>, <code class="inline-code">Mask</code>,{" "}
                <code class="inline-code">Defs</code>, <code class="inline-code">Use</code>,{" "}
                <code class="inline-code">Symbol</code>, <code class="inline-code">Image</code>. Inline{" "}
                <code class="inline-code">style</code> and <code class="inline-code">class</code> are
                translated into React Native style objects.
              </p>
            </div>

            <!-- Vue -->
            <div data-fw-show="vue" class="hidden">
                              <CodeBlock code={`<script setup lang="ts">
  import { SVG } from "@mhaadi/svg/vue";
</script>

<template>
  <SVG
    src="https://cdn.example.com/icon.svg"
    :width=24
    :height=24
    class="h-6 w-6 text-current"
  />

  <SVG src="/icon.svg">
    <template #loading>Loading…</template>
    <template #fallback>Failed</template>
  </SVG>
</template>`} lang="vue" />
              <p class="docs-body mt-4">
                Loading and fallback are exposed as named slots. <code class="inline-code">svg-load</code> and{" "}
                <code class="inline-code">svg-error</code> events are emitted when the markup resolves or fails.
              </p>
            </div>

            <!-- Svelte -->
            <div data-fw-show="svelte" class="hidden">
                              <CodeBlock code={`<script lang="ts">
  import { SVG } from "@mhaadi/svg/svelte";
</script>

<SVG
  src="https://cdn.example.com/icon.svg"
  width="24"
  height="24"
/>

<SVG src="/icon.svg">
  {#snippet loading()}Loading…{/snippet}
  {#snippet fallback()}Failed{/snippet}
</SVG>`} lang="svelte" />
              <p class="docs-body mt-4">
                Svelte 5 uses the runes API. Pass <code class="inline-code">loading</code> and{" "}
                <code class="inline-code">fallback</code> as snippets.
              </p>
            </div>

            <!-- Flutter -->
            <div data-fw-show="flutter" class="hidden">
              <p class="mb-3 text-xs text-amber-400 font-mono">Not yet published — API preview</p>
                                <CodeBlock code={`import 'package:svg_flutter/svg_flutter.dart';

class MyIcon extends StatelessWidget {
  const MyIcon({super.key});

  @override
  Widget build(BuildContext context) {
    return const Svg(
      src: 'https://cdn.example.com/icon.svg',
      width: 24,
      height: 24,
      color: Color(0xFF111827),
      loading: CircularProgressIndicator(),
      fallback: Icon(Icons.broken_image),
    );
  }
}`} lang="dart" />
              <p class="docs-body mt-4">
                svg_flutter renders via <code class="inline-code">flutter_svg</code>'s{" "}
                <code class="inline-code">SvgPicture.string</code>. Sanitization runs against the raw markup
                before render.
              </p>
            </div>
          </section>

          <!-- PROPS -->
          <section id="props" class="mb-16">
            <h2 class="docs-heading">Props</h2>
            <p class="docs-body">
              The base prop set is shared across all adapters. Framework-specific extras are
              documented in the <a href="#framework-specifics" class="text-acid hover:underline">Framework Specifics</a> section.
            </p>

            <div class="mt-6 rounded-none border border-coal-4 overflow-x-auto prop-table-wrapper">
              <table class="prop-table">
                <thead>
                  <tr>
                    <th>Prop</th>
                    <th>Type</th>
                    <th>Default</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">src</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">string</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Inline SVG string, data: URL, or remote URL.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">name</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">string</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Resolves a local SVG by name. In JS: src/assets/svg → app/assets/svg → public/assets/svg. In Flutter: <code class="inline-code">localResolver(name)</code> → <code class="inline-code">assets/svg/{"{name}"}.svg</code>.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">sanitize</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">boolean</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">true</code></td>
                    <td class="text-zinc-muted text-sm">Removes scripts, event handlers, unsafe hrefs, and embedded HTML.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">cache</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">boolean</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">true</code></td>
                    <td class="text-zinc-muted text-sm">Cache remote SVG markup in memory by src URL.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">fetchOptions</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">RequestInit</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Passed to fetch() (JS/TS) or merged into the http.Client request (Flutter). Memoize to avoid re-fetching.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">loading</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">slot / ReactNode / Widget?</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Rendered while fetching or parsing SVG. Slots in Vue, snippets in Svelte.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">fallback</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">slot / ReactNode / Widget?</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Rendered when loading or parsing fails.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">onSvgLoad</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">(markup: string) =&gt; void</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Called after markup is successfully resolved.</td>
                  </tr>
                  <tr>
                    <td><code class="font-mono text-xs text-acid">onSvgError</code></td>
                    <td><code class="font-mono text-xs text-[#e8c97e]">(error) =&gt; void</code></td>
                    <td><code class="font-mono text-xs text-zinc-muted">—</code></td>
                    <td class="text-zinc-muted text-sm">Called when loading or parsing fails. JS receives an <code class="inline-code">Error</code>; Flutter receives an <code class="inline-code">Object</code>.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- FRAMEWORK SPECIFICS -->
          <section id="framework-specifics" class="mb-16">
            <h2 class="docs-heading">Framework Specifics</h2>
            <p class="docs-body">Extras and conventions unique to each adapter.</p>

            <div class="mt-6 space-y-6">
              <!-- React -->
              <div data-fw-show="react">
                <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                  <h3 class="mb-2 font-semibold text-[#e8e8e8]">React</h3>
                  <p class="text-sm text-zinc-muted mb-3">
                    All <code class="inline-code">React.SVGProps{"<SVGSVGElement>"}</code> are supported
                    and override any attributes parsed from SVG markup. Forwarded via{" "}
                    <code class="inline-code">React.forwardRef</code>.
                  </p>
                                  <CodeBlock code={`import { SVG } from "@mhaadi/svg/react";
import { SvgName } from "@mhaadi/svg";

const icons: SvgName[] = ["logo", "arrow"];`} lang="tsx" />
                </div>
              </div>

              <!-- React Native -->
              <div data-fw-show="react-native" class="hidden">
                <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                  <h3 class="mb-2 font-semibold text-[#e8e8e8]">React Native</h3>
                  <p class="text-sm text-zinc-muted mb-3">
                    Accepts the standard source props plus size, color, and paint overrides
                    that are translated to <code class="inline-code">react-native-svg</code> props.
                  </p>
                                  <CodeBlock code={`<SVG
  name="logo"
  width={24}
  height={24}
  color="#111827"
  fill="none"
  stroke="currentColor"
  strokeWidth={1.5}
  style={{ margin: 8 }}
/>`} lang="tsx" />
                </div>
              </div>

              <!-- Vue -->
              <div data-fw-show="vue" class="hidden">
                <div class="rounded-none border border-coal-4 bg-coal-1 p-5">
                  <h3 class="mb-2 font-semibold text-[#e8e8e8]">Vue 3</h3>
                  <p class="text-sm text-zinc-muted mb-3">
                    Root-level SVG attributes (width, height, viewBox, fill, stroke, role,
                    aria-label, aria-hidden) are forwarded. Events are kebab-cased
