{
  "name": "@mhaadi/svg",
  "version": "0.1.1",
  "description": "Inline SVG rendering for React, React Native, Vue, and Svelte.",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/svelte/SVG.svelte",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./react-native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/SVG.svelte.d.ts",
      "svelte": "./dist/svelte/SVG.svelte",
      "import": "./dist/svelte/SVG.svelte.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:js": "tsc -p tsconfig.json",
    "build:svelte": "node scripts/build-svelte.mjs",
    "build": "pnpm run build:js && pnpm run build:svelte",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@better-svg/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-native": "^0.73.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "^0.85.3",
    "react-native-svg": "^15.15.5",
    "svelte": "^5.56.3",
    "typescript": "catalog:",
    "vue": "^3.5.35"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
