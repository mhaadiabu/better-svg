    const mobilePanel = document.getElementById("docs-mobile-panel");
    const mobileChevron = document.getElementById("docs-mobile-sidebar-chevron");
    const mobileSection = mobileSidebarBtn?.querySelector("[data-mobile-section]");

    const sectionOrder = Array.from(sectionEls).map((el) => el.id);

    function updateActive() {
      const els = Array.from(sectionEls) as HTMLElement[];
      const trigger = window.scrollY + 80;
      let active = els[0]?.id ?? "";
      for (const el of els) {
        if (el.offsetTop <= trigger) {
          active = el.id;
        } else {
          break;
        }
      }
      sidebarLinks.forEach((a) => {
        const id = a.getAttribute("data-section") || a.getAttribute("data-toc");
        a.classList.toggle("active", id === active);
      });
      if (mobileSection) {
        mobileSection.textContent = sectionLabels[active] || "Overview";
      }
    }

    window.addEventListener("scroll", updateActive, { passive: true });
    updateActive();

    // ── Instant active feedback on click (before smooth scroll settles) ─
    function sidebarClickHandler(this: HTMLAnchorElement) {
      const id = this.getAttribute("data-section") || this.getAttribute("data-toc");
      if (!id) return;
      sidebarLinks.forEach((link) => {
        const linkId = link.getAttribute("data-section") || link.getAttribute("data-toc");
        link.classList.toggle("active", linkId === id);
      });
      if (mobileSection) {
        mobileSection.textContent = sectionLabels[id] || "Overview";
      }
    }
    sidebarLinks.forEach((a) => {
      a.addEventListener("click", sidebarClickHandler);
    });

    // ── Mobile sidebar ────────────────────────────────────────────
    function openMobileSidebar() {
      mobileOverlay?.classList.add("open");
      mobilePanel?.classList.add("open");
      document.body.style.overflow = "hidden";
      mobileChevron?.classList.add("rotate-180");
      window.setTimeout(() => {
        const firstLink = mobilePanel?.querySelector<HTMLElement>(".mobile-sidebar-link");
        (firstLink || mobilePanel)?.focus();
      }, 0);
    }
    function closeMobileSidebar() {
      mobileOverlay?.classList.remove("open");
      mobilePanel?.classList.remove("open");
      document.body.style.overflow = "";
      mobileChevron?.classList.remove("rotate-180");
      mobileSidebarBtn?.focus();
    }

    mobileSidebarBtn?.addEventListener("click", openMobileSidebar);
    mobileOverlay?.addEventListener("click", closeMobileSidebar);
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-sidebar-link"));
    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeMobileSidebar);
    });

    // ── Code blocks: header, copy & wrap buttons ─────────────────
    initCodeBlocks();

    // ── Docs search ───────────────────────────────────────────────
    const searchInput = document.getElementById("docs-search") as HTMLInputElement | null;
    const searchResults = document.getElementById("docs-search-results");

    const searchIndex = sectionOrder.map((id) => {
      const el = document.getElementById(id);
      return {
        id,
        title: sectionLabels[id] ?? id,
        text: el?.textContent ?? "",
      };
    });
    const fuse = new Fuse(searchIndex, { keys: ["title", "text"], threshold: 0.3 });
    let activeResult = -1;

    function renderSearchResults(query: string) {
      if (!searchResults) return;
      if (!query) {
        searchResults.classList.add("hidden");
        searchResults.innerHTML = "";
        activeResult = -1;
        return;
      }
      const results = fuse.search(query).slice(0, 6);
      if (results.length === 0) {
        searchResults.innerHTML = `<div class="docs-search-empty">No results</div>`;
      } else {
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        const re = new RegExp(`(${escaped})`, "gi");
        searchResults.innerHTML = results
          .map((r, i) => {
            const title = (sectionLabels[r.item.id] ?? r.item.id).replace(re, "<mark>$1</mark>");
            return `<a href="#${r.item.id}" class="docs-search-result" data-idx="${i}" data-id="${r.item.id}" role="option">${title}</a>`;
          })
          .join("");
      }
      searchResults.classList.remove("hidden");
      activeResult = -1;
    }

    function onSearchInput() {
      renderSearchResults(searchInput?.value.trim() ?? "");
    }

    function onSearchKeydown(e: KeyboardEvent) {
      const items = Array.from(searchResults?.querySelectorAll<HTMLElement>(".docs-search-result") ?? []);
      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeResult = Math.min(activeResult + 1, items.length - 1);
        items.forEach((item, i) => item.classList.toggle("is-active", i === activeResult));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeResult = Math.max(activeResult - 1, -1);
        items.forEach((item, i) => item.classList.toggle("is-active", i === activeResult));
      } else if (e.key === "Enter" && activeResult >= 0) {
        e.preventDefault();
        (items[activeResult] as HTMLAnchorElement).click();
      } else if (e.key === "Escape") {
        searchResults?.classList.add("hidden");
        searchInput?.blur();
      }
    }

    function onResultClick(this: HTMLAnchorElement, e: MouseEvent) {
      e.preventDefault();
      const id = this.dataset.id;
      if (id) {
        document.getElementById(id)?.scrollIntoView({ behavior: "smooth" });
        history.replaceState(null, "", `#${id}`);
      }
      searchResults?.classList.add("hidden");
      if (searchInput) searchInput.value = "";
    }

    function onDocClick(e: MouseEvent) {
      if (!searchInput?.contains(e.target as Node) && !searchResults?.contains(e.target as Node)) {
        searchResults?.classList.add("hidden");
      }
    }

    searchInput?.addEventListener("input", onSearchInput);
    searchInput?.addEventListener("keydown", onSearchKeydown);
    searchResults?.addEventListener("click", (e) => {
      const target = (e.target as HTMLElement).closest(".docs-search-result") as HTMLAnchorElement | null;
      if (target) onResultClick.call(target, e);
    });
    document.addEventListener("click", onDocClick);

    cleanup = () => {
      window.removeEventListener("scroll", updateActive);
      mobileSidebarBtn?.removeEventListener("click", openMobileSidebar);
      mobileOverlay?.removeEventListener("click", closeMobileSidebar);
      mobileLinks.forEach((link) => {
        link.removeEventListener("click", closeMobileSidebar);
      });
      sidebarLinks.forEach((a) => {
        a.removeEventListener("click", sidebarClickHandler);
      });
      searchInput?.removeEventListener("input", onSearchInput);
      searchInput?.removeEventListener("keydown", onSearchKeydown);
      document.removeEventListener("click", onDocClick);
    };
  }

  document.addEventListener("astro:page-load", initDocsPage);
  document.addEventListener("astro:before-swap", () => cleanup());
  initDocsPage();
</script>
