                    <pre class="p-4 text-sm leading-6"><span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-component">SVG</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg/react"</span><span class="token-punct">;</span>
<span class="token-keyword">import</span> <span class="token-punct">{"{ "}</span><span class="token-type">SvgName</span><span class="token-punct">{" }"}</span> <span class="token-keyword">from</span> <span class="token-string">"@mhaadi/svg"</span><span class="token-punct">;</span>

<span class="token-keyword">const</span> icons<span class="token-punct">:</span> <span class="token-type">SvgName</span><span class="token-punct">[]</span> <span class="token-punct">=</span> <span class="token-punct">["</span><span class="token-string">logo</span><span class="token-punct">", "</span><span class="token-string">arrow</span><span class="token-punct">"];</span></pre>
