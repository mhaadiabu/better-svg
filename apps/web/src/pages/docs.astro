  <span class="token-prop">style</span><span class="token-punct">=</span><span class="token-punct">{"{"}</span><span class="token-punct">{"{"}</span> margin<span class="token-punct">:</span> <span class="token-string">8</span> <span class="token-punct">{"}"}</span><span class="token-punct">{"}"}</span>
<span class="token-punct">{"/>"}</span></pre>
